{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harvest",
  "version": "0.1.0",
  "identifier": "com.syqs.harvest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Harvest",
        "width": 1120,
        "height": 720,
        "minWidth": 640,
        "minHeight": 560,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/yt-dlp", "binaries/gallery-dl", "binaries/ffmpeg"],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Syqs19/Harvest/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwNjUzMkM2NjRGRUY0QjIKUldTeTlQNWt4akpsUUFWM1VrOGw1NjlTUHEwdkJyclBEK1lXNkFSeWFENHRrVHFFQ3RFV21CM1UK"
    }
  }
}
